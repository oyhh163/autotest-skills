# 飞书应用配置
# 从飞书开放平台获取: https://open.feishu.cn/app
LARK_APP_ID=cli_xxxxxxxxxxxxxx
LARK_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 飞书事件订阅配置（从应用配置页面获取）
LARK_VERIFICATION_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LARK_ENCRYPT_KEY=  # 可选，如果启用了加密

# Cursor API Key
# 从 Cursor Dashboard 获取: https://cursor.com/dashboard/integrations
CURSOR_API_KEY=cursor_xxxxxxxxxxxxxxxx

# Cursor 模型选择（可选，默认 composer-2.5）
CURSOR_MODEL=composer-2.5

# Bug 记录多维表格配置（可选）
# 如果配置了，Bug会自动记录到多维表格
LARK_BASE_TOKEN=bascnxxxxxxxxxxxxxxxxxx
LARK_TABLE_ID=tblxxxxxxxxxxxxxxxxxx

# 服务配置
PORT=3000

# 测试系统配置（可选，使用默认值）
# TEST_SKILL_PATH=c:\Users\oywor\.agents\skills\test-system-flow
# TEST_OUTPUT_PATH=c:\Users\oywor\.agents\skills\test-output
